  },
  "author": "kerns <david@kerns.dk>",
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "optionalDependencies": {
    "@zeb-link/zeb-darwin-arm64": "0.3.0",
    "@zeb-link/zeb-darwin-x64": "0.3.0",
    "@zeb-link/zeb-linux-arm64": "0.3.0",
    "@zeb-link/zeb-linux-x64": "0.3.0",
    "@zeb-link/zeb-win32-arm64": "0.3.0",
    "@zeb-link/zeb-win32-x64": "0.3.0"
  }
